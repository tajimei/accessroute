rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ユーザープロファイル: 自分のデータのみ読み書き可能
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // スポットデータ: 認証済みユーザーのみ読み取り可能、書き込みは管理者のみ
    match /spots/{spotId} {
      allow read: if request.auth != null;
      allow write: if false; // 管理者のみ（Admin SDK経由）
    }

    // スポットキャッシュ: Admin SDK経由のみ
    match /spots_cache/{spotId} {
      allow read, write: if false; // Admin SDK経由のみ
    }

    // 検索履歴: 自分のデータのみ読み取り可能、書き込みはAdmin SDK経由
    match /search_history/{historyId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false; // Admin SDK経由のみ
    }

    // 会話履歴: ユーザーは自分の会話のみアクセス可能、書き込みはAdmin SDK経由
    match /conversations/{conversationId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false; // Admin SDK経由のみ
    }

    // その他のドキュメントはデフォルト拒否
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

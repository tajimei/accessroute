# ============================================================
# AccessRoute AI推論サーバー - 本番用Dockerfile
# マルチステージビルドでイメージサイズを最小化
# ============================================================

# --- ステージ1: 依存パッケージのビルド ---
FROM nvidia/cuda:12.1.1-devel-ubuntu22.04 AS builder

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        python3.11 python3.11-venv python3.11-dev python3-pip \
        git build-essential && \
    ln -sf /usr/bin/python3.11 /usr/bin/python && \
    ln -sf /usr/bin/python3.11 /usr/bin/python3 && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# venv を作成して依存パッケージをインストール
RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

COPY requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r /tmp/requirements.txt

# --- ステージ2: 本番用ランタイム ---
FROM nvidia/cuda:12.1.1-runtime-ubuntu22.04 AS runtime

# 最小限のランタイム依存パッケージのみインストール
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        python3.11 python3.11-venv \
        curl && \
    ln -sf /usr/bin/python3.11 /usr/bin/python && \
    ln -sf /usr/bin/python3.11 /usr/bin/python3 && \
    apt-get clean && rm -rf /var/lib/apt/lists/* && \
    rm -rf /tmp/* /var/tmp/*

# ビルドステージからvenvをコピー
COPY --from=builder /opt/venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# セキュリティ: 非rootユーザーで実行
RUN groupadd -r appuser && useradd -r -g appuser -d /app -s /sbin/nologin appuser

WORKDIR /app

# アプリケーションコードのみコピー（テスト・ベンチマーク等は除外）
COPY server.py config.py parser.py model_manager.py monitor.py ./
COPY prompts/ ./prompts/

# ディレクトリの所有権を変更
RUN chown -R appuser:appuser /app

USER appuser

# ヘルスチェック
HEALTHCHECK --interval=30s --timeout=10s --start-period=120s --retries=3 \
    CMD curl -sf http://localhost:8000/health || exit 1

EXPOSE 8000

# uvicornをワーカー1で起動（vLLMが内部で並列処理を行うため）
CMD ["python", "-u", "server.py"]
